generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EncounterType {
  OUTPATIENT
  INPATIENT
  EMERGENCY
  TELEHEALTH
  FOLLOW_UP
}

enum DiagnosisStatus {
  ACTIVE
  RESOLVED
  CHRONIC
  SUSPECTED
}

enum DocumentType {
  LAB_RESULT
  XRAY
  SCAN
  DISCHARGE_SUMMARY
  REFERRAL
  OTHER
}

model Encounter {
  id             String        @id @default(uuid())
  patientDid     String
  providerDid    String
  facilityId     String?
  encounterType  EncounterType @default(OUTPATIENT)
  chiefComplaint String?
  notes          String?
  encounterDate  DateTime      @default(now())
  dischargeDate  DateTime?
  isOfflineSync  Boolean       @default(false)
  diagnoses      Diagnosis[]
  prescriptions  Prescription[]
  vitals         Vitals[]
  documents      Document[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([patientDid])
  @@index([providerDid])
  @@map("encounters")
}

model Diagnosis {
  id          String          @id @default(uuid())
  encounter   Encounter       @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  encounterId String
  patientDid  String
  icd10Code   String?
  description String
  status      DiagnosisStatus @default(ACTIVE)
  severity    String?
  diagnosedBy String
  createdAt   DateTime        @default(now())

  @@index([patientDid])
  @@map("diagnoses")
}

model Prescription {
  id             String    @id @default(uuid())
  encounter      Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  encounterId    String
  patientDid     String
  drugName       String
  genericName    String?
  dosage         String
  frequency      String
  durationDays   Int
  instructions   String?
  dispensed      Boolean   @default(false)
  dispensedAt    DateTime?
  dispensedBy    String?
  prescribedBy   String
  createdAt      DateTime  @default(now())

  @@index([patientDid])
  @@map("prescriptions")
}

model Vitals {
  id              String    @id @default(uuid())
  encounter       Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  encounterId     String
  patientDid      String
  recordedAt      DateTime  @default(now())
  temperatureC    Float?
  bloodPressure   String?
  pulseRate       Int?
  respiratoryRate Int?
  weightKg        Float?
  heightCm        Float?
  bmi             Float?
  oxygenSat       Float?
  bloodGlucose    Float?
  recordedBy      String

  @@index([patientDid])
  @@map("vitals")
}

model Document {
  id           String       @id @default(uuid())
  encounter    Encounter    @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  encounterId  String
  patientDid   String
  documentType DocumentType @default(OTHER)
  fileName     String
  fileSize     Int?
  mimeType     String?
  storagePath  String
  uploadedBy   String
  uploadedAt   DateTime     @default(now())

  @@index([patientDid])
  @@map("documents")
}
